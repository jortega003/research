    "from factor_analyzer import FactorAnalyzer\n",
    "\n",
    "def compute_cct(dataframe, n_factors=3, return_ev=False):\n",
    "    '''\n",
    "    Returns the Cultural Consensus Theory answer for a given dataset.\n",
    "\n",
    "    Parameters\n",
    "    ----------\n",
    "    dataframe : pd.DataFrame\n",
    "        Each column is an individual observer's response.\n",
    "    n_factors : int\n",
    "        Number of factors to fit. Default 3 (conservative: allows bi-modal consensus).\n",
    "    return_ev : bool\n",
    "        If True, also returns the eigenvalue ratio (factor1/factor2).\n",
    "        A ratio >= 3 suggests a single dominant correct answer [1].\n",
    "\n",
    "    References\n",
    "    ----------\n",
    "    [1] https://journals.sagepub.com/doi/10.1177/1525822X07303502\n",
    "    '''\n",
    "    fa = FactorAnalyzer(rotation=None)\n",
    "    fa.fit(dataframe, n_factors)\n",
    "    ev, _ = fa.get_eigenvalues()\n",
    "    ev_ratio = ev[0] / ev[1]\n",
    "    cct_m = fa.transform(dataframe)[:, 0]  # factor 1 weighted average\n",
    "    return (cct_m, ev_ratio) if return_ev else cct_m\n",
    "\n",
    "\n",
    "def normalize_corr(signal, a=-1, b=1):\n",
    "    \"\"\"Min-max normalize signal to [a, b].\"\"\"\n",
    "    A = signal.min().min()\n",
    "    B = signal.max().max()\n",
    "    C = (a - b) / (A - B)\n",
    "    k = (C * A - a) / C\n",
    "    return (signal - k) * C\n",
    "\n",
    "\n",
    "def outlier_remover(x, z=4):\n",
    "    \"\"\"Z-score outlier removal with forward/backward fill for missing values.\"\"\"\n",
    "    xc = x.replace(9999, np.nan)          # treat blink marker as NaN\n",
    "    xz = (xc - xc.mean()) / xc.std()      # z-score\n",
    "    xz[xz > z] = np.nan                   # clip high outliers\n",
    "    xz[xz < -z] = np.nan                  # clip low outliers\n",
    "    xz = xz.ffill()                        # forward-fill gaps\n",
    "    xz = xz.bfill()                        # back-fill any leading NaNs\n",
    "    return xz\n",
    "\n",
    "\n",
    "def corrmean(data):\n",
    "    \"\"\"\n",
    "    Fisher Z-transform mean for correlation values.\n",
    "    Clips input to [-0.999999, 0.999999] to avoid arctanh(+-1) = +-inf.\n",
    "    \"\"\"\n",
    "    data = np.clip(np.array(data, dtype=float), -0.999999, 0.999999)\n",
    "    return np.tanh(np.nanmean(np.arctanh(data)))\n",
    "\n",
    "\n",
    "def bootstrap_mean_corr(data, lo_ci=2.5, hi_ci=97.5, reps=5000):\n",
    "    \"\"\"Bootstrap mean and 95% CI using Fisher Z-transformation (for correlations).\"\"\"\n",
    "    n = len(data)\n",
    "    data = np.array(data)\n",
    "    boot_data = [data[np.random.choice(range(n), size=n, replace=True)] for _ in range(reps)]\n",
    "    means = [np.tanh(np.nanmean(np.arctanh(x))) for x in boot_data]\n",
    "    m = np.tanh(np.nanmean(np.arctanh(means)))\n",
    "    ci = np.nanpercentile(means, [lo_ci, hi_ci])\n",
    "    return m, ci\n",
    "\n",
    "\n",
    "def bootstrap_mean(data, lo_ci=2.5, hi_ci=97.5, reps=5000):\n",
    "    \"\"\"Bootstrap mean and 95% CI (for non-correlation data).\"\"\"\n",
    "    n = len(data)\n",
    "    data = np.array(data)\n",
    "    boot_data = [data[np.random.choice(range(n), size=n, replace=True)] for _ in range(reps)]\n",
    "    means = [np.nanmean(x) for x in boot_data]\n",
    "    m = np.nanmean(means)\n",
    "    ci = np.nanpercentile(means, [lo_ci, hi_ci])\n",
    "    return m, ci\n"
   ]
