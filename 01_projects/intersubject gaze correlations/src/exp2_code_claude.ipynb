    "def ccc_matrix(df, alpha=1.0):\n",
    "    \"\"\"\n",
    "    Compute Lin's Concordance Correlation Coefficient (CCC) matrix for all subject pairs.\n",
    "\n",
    "    Vectorized — replaces the O(n²) nested loop with matrix operations.\n",
    "    Preserves original ddof convention: covariance uses ddof=1, variance uses ddof=0.\n",
    "\n",
    "    Parameters\n",
    "    ----------\n",
    "    df : pd.DataFrame\n",
    "        Time x Subjects data matrix.\n",
    "    alpha : float\n",
    "        Exponent applied to Pearson r. Default 1.0 (standard CCC).\n",
    "\n",
    "    Returns\n",
    "    -------\n",
    "    pd.DataFrame\n",
    "        Symmetric N x N CCC matrix with 1s on the diagonal.\n",
    "    \"\"\"\n",
    "    X = df.values.astype(float)   # (T, N)\n",
    "    T, N = X.shape\n",
    "    cols = df.columns\n",
    "\n",
    "    mu = X.mean(axis=0)            # (N,) column means\n",
    "    Xc = X - mu                    # (T, N) mean-centered\n",
    "\n",
    "    # Covariance (ddof=1) — matches original np.cov behaviour\n",
    "    cov = (Xc.T @ Xc) / (T - 1)   # (N, N)\n",
    "\n",
    "    # Variance (ddof=0) — matches original np.var behaviour\n",
    "    var = Xc.var(axis=0)           # (N,)\n",
    "    std = np.sqrt(var)\n",
    "\n",
    "    # Pearson r matrix (denominator uses ddof=0 stds)\n",
    "    outer_std = np.outer(std, std)\n",
    "    r_mat = np.divide(cov, outer_std,\n",
    "                      out=np.zeros((N, N)), where=outer_std != 0)\n",
    "\n",
    "    # CCC = 2 * sxy / (var_x + var_y + (mean_x - mean_y)^2)\n",
    "    mu_diff_sq = np.subtract.outer(mu, mu) ** 2  # (N, N)\n",
    "    denom = var[:, None] + var[None, :] + mu_diff_sq\n",
    "    ccc = np.divide(2 * cov, denom,\n",
    "                    out=np.zeros((N, N)), where=denom != 0)\n",
    "\n",
    "    # Alpha weighting (no-op when alpha=1.0)\n",
    "    if alpha != 1.0:\n",
    "        cb = np.divide(ccc, r_mat, out=np.zeros((N, N)), where=r_mat != 0)\n",
    "        ccc = (r_mat ** alpha) * cb\n",
    "\n",
    "    np.fill_diagonal(ccc, 1.0)\n",
    "    return pd.DataFrame(ccc, index=cols, columns=cols)\n"
   ]
  },
