    "import numpy as np\n",
    "from scipy import stats\n",
    "from tqdm import tqdm\n",
    "\n",
    "# Note: fisher_mean is replaced by corrmean() defined in Cell 1, which now\n",
    "# includes the same protective clip to [-0.999999, 0.999999].\n",
    "\n",
    "def fast_spearman_col_wise(X, Y):\n",
    "    \"\"\"\n",
    "    Vectorized column-wise Spearman correlation between matrices X and Y.\n",
    "    X and Y must have shape (Time, Subjects).\n",
    "    Returns a correlation vector of shape (Subjects,).\n",
    "    \"\"\"\n",
    "    X_ranked = stats.rankdata(X, axis=0)\n",
    "    Y_ranked = stats.rankdata(Y, axis=0)\n",
    "    X_c = X_ranked - X_ranked.mean(axis=0)\n",
    "    Y_c = Y_ranked - Y_ranked.mean(axis=0)\n",
    "    numer = np.sum(X_c * Y_c, axis=0)\n",
    "    denom = np.sqrt(np.sum(X_c**2, axis=0)) * np.sqrt(np.sum(Y_c**2, axis=0))\n",
    "    return np.divide(numer, denom, out=np.zeros_like(numer), where=denom != 0)\n",
    "\n",
    "\n",
    "# --- 1. Pre-computation: convert DataFrames to NumPy arrays once ---\n",
    "video_data = {}\n",
    "video_keys = list(context_rating_data.keys())\n",
    "\n",
    "for v in video_keys:\n",
    "    clean_df = context_rating_data[v].dropna()\n",
    "    video_data[v] = {\n",
    "        'data': clean_df.to_numpy(),\n",
    "        'subjects': clean_df.columns.tolist(),\n",
    "        'is_valence': 'valence' in v\n",
    "    }\n",
    "\n",
    "a_perm = []\n",
    "v_perm = []\n",
    "\n",
    "# --- 2. Permutation loop ---\n",
    "n_perms = 10\n",
    "for _ in tqdm(range(n_perms)):\n",
    "\n",
    "    perm_valence_corrs = []\n",
    "    perm_arousal_corrs = []\n",
    "\n",
    "    shuffled_keys = np.random.choice(video_keys, len(video_keys), replace=False)\n",
    "\n",
    "    for v1_key, v2_key in zip(video_keys, shuffled_keys):\n",
    "\n",
    "        v1_struct = video_data[v1_key]\n",
    "        v2_struct = video_data[v2_key]\n",
    "\n",
    "        min_len = min(v1_struct['data'].shape[0], v2_struct['data'].shape[0])\n",
    "        mat_v1 = v1_struct['data'][:min_len, :]\n",
    "        mat_v2 = v2_struct['data'][:min_len, :]\n",
    "\n",
    "        # Vectorized leave-one-out consensus for v2\n",
    "        n_subjs = mat_v2.shape[1]\n",
    "        if n_subjs <= 1:\n",
    "            continue\n",
    "        sum_rows = np.sum(mat_v2, axis=1, keepdims=True)\n",
    "        consensus_mat_v2 = (sum_rows - mat_v2) / (n_subjs - 1)\n",
    "\n",
    "        r_values = fast_spearman_col_wise(mat_v1, consensus_mat_v2)\n",
    "\n",
    "        if v1_struct['is_valence']:\n",
    "            perm_valence_corrs.extend(r_values)\n",
    "        else:\n",
    "            perm_arousal_corrs.extend(r_values)\n",
    "\n",
    "    # Aggregate using Fisher Z-transform mean (corrmean from Cell 1)\n",
    "    v_perm.append(corrmean(np.array(perm_valence_corrs)) if perm_valence_corrs else np.nan)\n",
    "    a_perm.append(corrmean(np.array(perm_arousal_corrs)) if perm_arousal_corrs else np.nan)\n"
   ]
