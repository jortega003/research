    "for v_key in context_gaze_data:\n",
    "    if 'pupil' in v_key:\n",
    "        continue\n",
    "    clean_gaze_data[v_key] = context_gaze_data[v_key].to_numpy()\n",
    "    valid_video_keys.append(v_key)\n",
    "\n",
    "# --- 2. Permutation loop ---\n",
    "isc_perm = []\n",
    "n_perms = 10\n",
    "\n",
    "print(\"Running ISC permutations...\")\n",
    "for _ in tqdm(range(n_perms)):\n",
    "\n",
    "    perm_correlations = []\n",
    "    shuffled_keys = np.random.choice(valid_video_keys, len(valid_video_keys), replace=False)\n",
    "\n",
    "    for v_orig, v_shuff in zip(valid_video_keys, shuffled_keys):\n",
    "\n",
    "        data_orig = clean_gaze_data[v_orig]\n",
    "        data_shuff = clean_gaze_data[v_shuff]\n",
    "\n",
    "        min_len = min(data_orig.shape[0], data_shuff.shape[0])\n",
    "        if min_len < 2:\n",
    "            continue\n",
    "\n",
    "        r_vals = fast_col_corr(data_orig[:min_len], data_shuff[:min_len])\n",
    "        perm_correlations.extend(r_vals[~np.isnan(r_vals)])\n",
    "\n",
    "    # Aggregate using Fisher Z-transform mean (corrmean from Cell 1)\n",
