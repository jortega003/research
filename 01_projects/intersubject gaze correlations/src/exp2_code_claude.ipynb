    "import numpy as np\n",
    "from tqdm import tqdm\n",
    "\n",
    "# Note: fisher_mean is replaced by corrmean() from Cell 1.\n",
    "\n",
    "def fast_col_corr(A, B):\n",
    "    \"\"\"\n",
    "    Vectorized column-wise Pearson correlation between matrices A and B.\n",
    "    A and B must be (Time, Subjects). Returns a correlation vector of shape (Subjects,).\n",
    "    \"\"\"\n",
    "    A_c = A - np.mean(A, axis=0)\n",
    "    B_c = B - np.mean(B, axis=0)\n",
    "    numer = np.sum(A_c * B_c, axis=0)\n",
    "    denom = np.sqrt(np.sum(A_c**2, axis=0)) * np.sqrt(np.sum(B_c**2, axis=0))\n",
    "    return np.divide(numer, denom, out=np.zeros_like(numer), where=denom != 0)\n",
