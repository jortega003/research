    "def split_list(data, n_splits=4, test_ratio=0.25):\n",
    "    random.shuffle(data)\n",
    "    size = len(data)\n",
    "    test_size = int(size * test_ratio)\n",
    "\n",
    "    splits = {}\n",
    "    for i in range(n_splits):\n",
    "        test = data[i * test_size : (i + 1) * test_size]\n",
    "        train = [x for x in data if x not in test]\n",
    "        splits[i + 1] = {\"train\": train, \"test\": test}\n",
    "    \n",
    "    return splits\n",
    "\n",
    "\n",
    "cv = split_list(list(performance.keys()))"
