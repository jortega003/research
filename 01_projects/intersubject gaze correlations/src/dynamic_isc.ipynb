   "outputs": [],
   "source": [
    "# calculating dynamic ISC\n",
    "\n",
    "top_dynamic_isc_rating = {}\n",
    "bot_dynamic_isc_rating = {}\n",
    "\n",
    "for video in rating_data:\n",
    "        \n",
    "    df = outlier_remover(rating_data[video].dropna())\n",
    "    \n",
    "    if video not in top_dynamic_isc_rating:\n",
    "        top_dynamic_isc_rating[video] = pd.DataFrame()\n",
    "        bot_dynamic_isc_rating[video] = pd.DataFrame()\n",
    "        \n",
    "    # get only top observers\n",
    "    ss = [s for s in topObs if s in df]\n",
    "    df_ = df[ss]\n",
    "    \n",
    "    for subject in df_.columns:\n",
    "        sr = df_[subject]\n",
    "        cr = df_.drop(columns = [subject]).mean(axis = 1)\n",
    "        corr = sr.rolling(375).corr(cr)\n",
    "        top_dynamic_isc_rating[video] = pd.concat([top_dynamic_isc_rating[video],corr.rename(subject)],axis = 1)\n",
    "\n",
    "    # get only bottom observers\n",
    "    ss = [s for s in botObs if s in df]\n",
    "    df_ = df[ss]\n",
    "    \n",
    "    for subject in df_.columns:\n",
    "        sr = df_[subject]\n",
    "        cr = df_.drop(columns = [subject]).mean(axis = 1)\n",
    "        corr = sr.rolling(375).corr(cr)\n",
    "        bot_dynamic_isc_rating[video] = pd.concat([bot_dynamic_isc_rating[video],corr.rename(subject)],axis = 1)\n"
   ]
  },
