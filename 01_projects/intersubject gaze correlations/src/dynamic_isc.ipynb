    "\n",
    "            if video not in perm_top:\n",
    "                perm_top[video] = pd.DataFrame()\n",
    "                perm_bot[video] = pd.DataFrame()\n",
    "\n",
    "\n",
    "            # get only top observers\n",
    "            ss = [s for s in topObs_perm if s in df]\n",
    "            df_ = df[ss]\n",
    "\n",
    "            for subject in df_.columns:\n",
    "                sr = df_[subject]\n",
    "                cr = df_.drop(columns = [subject]).mean(axis = 1)\n",
    "                corr = sr.rolling(375).corr(cr)\n",
    "                perm_top[video] = pd.concat([perm_top[video],corr.rename(subject)],axis = 1)\n",
    "\n",
    "            # get only bottom observers\n",
    "            ss = [s for s in botObs_perm if s in df]\n",
    "            df_ = df[ss]\n",
    "\n",
    "            for subject in df_.columns:\n",
    "                sr = df_[subject]\n",
    "                cr = df_.drop(columns = [subject]).mean(axis = 1)\n",
    "                corr = sr.rolling(375).corr(cr)\n",
    "                perm_bot[video] = pd.concat([perm_bot[video],corr.rename(subject)],axis = 1)\n",
    "\n",
    "\n",
    "        for video in gaze_data:\n",
    "            if video not in disc_permutation_cv:\n",
    "                disc_permutation_cv[video] = pd.DataFrame()\n",
    "\n",
    "            diff = perm_top[video].mean(axis = 1) - perm_bot[video].mean(axis = 1)\n",
    "            disc_permutation_cv[video] = pd.concat([disc_permutation_cv[video],diff],axis = 1)\n",
    "\n",
    "    epochs_cv = {}\n",
    "\n",
    "    for video in gaze_data:\n",
    "        if 'pupil' in video:\n",
    "            continue\n",
    "\n",
    "        if video not in epochs_cv:\n",
    "            epochs_cv[video] = []\n",
    "\n",
    "        diff = top_dynamic_isc_video_cv[video].mean(axis = 1) - bot_dynamic_isc_video_cv[video].mean(axis = 1)\n",
    "        ci = disc_permutation_cv[video].apply(ci34,axis = 1)\n",
    "\n",
    "\n",
    "        all_points = []\n",
    "\n",
    "        for i in ci.iloc[374:].index: # skip first 5 seconds\n",
    "\n",
    "            if not ci[i][0] < diff[i] < ci[i][1]:\n",
    "                if diff[i] > 0:\n",
    "                    all_points.append(i)\n",
    "\n",
    "        epochs_cv[video] = find_epochs(all_points)\n",
    "\n",
    "    # calculate ISC for each epoch\n",
    "    disc_cv = {}\n",
    "\n",
    "    for video in epochs_cv:\n",
    "        df = outlier_remover(gaze_data[video].dropna())\n",
    "\n",
    "        for i in epochs_cv[video]:\n",
    "            e = df.iloc[i[0]:i[1]]\n",
    "\n",
    "            if len(e) < 375:\n",
    "                continue\n",
    "\n",
    "\n",
    "            for subject in e.columns:\n",
    "                if subject == 'BF087_1':\n",
    "                    continue\n",
    "                \n",
    "                if subject not in test:\n",
    "                    continue\n",
    "                sr = e[subject]\n",
    "                cr = e.drop(columns = [subject]).mean(axis = 1)\n",
    "                r, p = stats.pearsonr(sr,cr)\n",
    "\n",
    "                if subject not in disc_cv:\n",
    "                    disc_cv[subject] = []\n",
    "\n",
    "                disc_cv[subject].append(r)\n",
    "\n",
    "    discAvg_cv = {s:corrmean(disc_cv[s]) for s in disc_cv}\n",
    "    cv_sets[s] = discAvg_cv"
   ]
