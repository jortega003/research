    "def ci95(x):\n",
    "    return np.nanpercentile(x,[2.5,97.5])\n",
    "\n",
    "def ci90(x):\n",
    "    return np.nanpercentile(x,[5,95])\n",
    "\n",
    "def ci68(x):\n",
    "    return np.nanpercentile(x,[16,84])\n",
    "\n",
    "def ci34(x):\n",
    "    return np.nanpercentile(x,[32,66])\n",
    "\n",
    "def find_epochs(time_points):\n",
    "    \"\"\"\n",
    "    Find start and end indices of consecutive epochs in a list.\n",
    "    \n",
    "    Parameters\n",
    "    ----------\n",
    "    time_points : list[int]\n",
    "        List of time points (e.g., epochs)\n",
    "    \n",
    "    Returns\n",
    "    -------\n",
    "    list[list[int]]\n",
    "        List of [start, end] pairs for each consecutive range\n",
    "    \"\"\"\n",
    "    \n",
    "    if not time_points:\n",
    "        return []\n",
    "    \n",
    "    # Ensure sorted (if needed)\n",
    "    time_points = sorted(time_points)\n",
    "    \n",
    "    ranges = []\n",
    "    start = time_points[0]\n",
    "    prev = time_points[0]\n",
    "    \n",
    "    for t in time_points[1:]:\n",
    "        if t == prev + 1:\n",
    "            # still consecutive\n",
    "            prev = t\n",
    "        else:\n",
    "            # break in sequence → save current range\n",
    "            ranges.append([start, prev])\n",
    "            start = t\n",
    "            prev = t\n",
    "    \n",
    "    # Add the last range\n",
    "    ranges.append([start, prev])\n",
    "    \n",
    "    return ranges\n"
   ]
  },
