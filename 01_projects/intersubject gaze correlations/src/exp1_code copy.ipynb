    "import pandas as pd\n",
    "from pathlib import Path\n",
    "from collections import defaultdict\n",
    "\n",
    "data_dir = Path('/home/Jeff/1.0 projects/intersubject gaze correlations/data/experiment 1/')\n",
    "\n",
    "# Temporary storage: lists are faster to append to than DataFrames\n",
    "temp_storage = {\n",
    "    'gaze': {'context': defaultdict(list), 'ground': defaultdict(list)},\n",
    "    'rating': {'context': defaultdict(list), 'ground': defaultdict(list)}\n",
    "}\n",
    "\n",
    "def process_file(file_path, category, subject_id):\n",
    "    \"\"\"Loads, cleans, and stores columns into temp lists.\"\"\"\n",
    "    condition = 'context' if 'context' in file_path.name else 'ground'\n",
    "    \n",
    "    # Load and clean\n",
    "    df = pd.read_csv(file_path).iloc[:, 1:].dropna()\n",
    "    df = outlier_remover(df) \n",
    "\n",
    "    # Append columns to lists\n",
    "    for col in df.columns:\n",
    "        temp_storage[category][condition][col].append(df[col].rename(subject_id))\n",
    "\n",
    "# Iterate through folders\n",
    "for folder in data_dir.iterdir():\n",
    "\n",
    "    # Find files safely\n",
    "    try:\n",
    "        files = list(folder.glob('*'))\n",
    "        gaze_file = next(f for f in files if 'gaze' in f.name)\n",
    "        rating_file = next(f for f in files if 'context' in f.name or 'ground' in f.name)\n",
    "    except StopIteration:\n",
    "        continue # Skip if files are missing\n",
    "\n",
    "    process_file(gaze_file, 'gaze', folder.name)\n",
    "    process_file(rating_file, 'rating', folder.name)\n",
    "\n",
    "# Final Compile: Convert lists of Series into DataFrames\n",
    "def compile_data(storage_dict):\n",
    "    return {k: pd.concat(v, axis=1) for k, v in storage_dict.items()}\n",
    "\n",
    "context_gaze_data = compile_data(temp_storage['gaze']['context'])\n",
    "ground_gaze_data  = compile_data(temp_storage['gaze']['ground'])\n",
    "context_rating_data = compile_data(temp_storage['rating']['context'])\n",
    "ground_rating_data  = compile_data(temp_storage['rating']['ground'])"
   ]
