   "source": [
    "import pandas as pd\n",
    "from scipy import stats\n",
    "from collections import defaultdict\n",
    "\n",
    "def get_performance_metrics(data_dict, skip_substring=None):\n",
    "    \"\"\"\n",
    "    Calculates Leave-One-Out correlation performance for all subjects.\n",
    "    Returns dictionaries for Total, Valence, and Arousal performance.\n",
    "    \"\"\"\n",
    "    # 1. Use defaultdict to avoid repeated initialization checks\n",
    "    perf_all = defaultdict(list)\n",
    "    perf_val = defaultdict(list)\n",
    "    perf_aro = defaultdict(list)\n",
    "\n",
    "    for video, df in data_dict.items():\n",
    "        # Optional: Skip videos containing specific substrings (e.g. skipping 'ground' in context data)\n",
    "        if skip_substring and skip_substring in video:\n",
    "            continue\n",
    "\n",
    "        df = df.dropna()\n",
    "        n_subjs = df.shape[1]\n",
    "        \n",
    "        if n_subjs < 2: continue # Cannot calc correlation with < 2 people\n",
    "\n",
    "        # 2. OPTIMIZATION: \"Sum minus Self\"\n",
    "        # Instead of dropping columns inside the loop (slow), \n",
    "        # calc the Total Sum once, then subtract the individual to get the rest.\n",
    "        total_sum = df.sum(axis=1)\n",
    "        \n",
    "        for subj in df.columns:\n",
    "            subj_data = df[subj]\n",
    "            \n",
    "            # Calculate mean of everyone else: (Total - Self) / (N-1)\n",
    "            # Note: Pearson r is scale invariant, so dividing by (n_subjs - 1) \n",
    "            # isn't strictly necessary for 'r', but good for correctness of the 'mean'.\n",
    "            consensus = (total_sum - subj_data) / (n_subjs - 1)\n",
    "            \n",
    "            r, _ = stats.pearsonr(subj_data, consensus)\n",
    "            \n",
    "            # Store results\n",
    "            perf_all[subj].append(r)\n",
    "            if 'valence' in video:\n",
    "                perf_val[subj].append(r)\n",
    "            else:\n",
    "                perf_aro[subj].append(r)\n",
    "\n",
    "    return perf_all, perf_val, perf_aro\n",
    "\n",
    "def calc_averages(perf_dict):\n",
    "    \"\"\"Helper to apply corrmean to values\"\"\"\n",
    "    return {s: corrmean(scores) for s, scores in perf_dict.items()}\n",
    "\n",
    "# --- EXECUTION ---\n",
    "\n",
    "# 1. Process Ground\n",
    "ground_perf, ground_val, ground_aro = get_performance_metrics(ground_rating_data)\n",
    "\n",
    "ground_avg_taskPerf = calc_averages(ground_perf)\n",
    "ground_avg_taskPerf_valence = calc_averages(ground_val)\n",
    "ground_avg_taskPerf_arousal = calc_averages(ground_aro)\n",
    "\n",
    "# 2. Process Context (filtering out any accidental 'ground' keys if necessary)\n",
    "context_perf, context_val, context_aro = get_performance_metrics(\n",
    "    context_rating_data, \n",
    "    skip_substring='ground'\n",
    ")\n",
    "\n",
    "context_avg_taskPerf = calc_averages(context_perf)\n",
    "context_avg_taskPerf_valence = calc_averages(context_val)\n",
    "context_avg_taskPerf_arousal = calc_averages(context_aro)"
   ]
  },
