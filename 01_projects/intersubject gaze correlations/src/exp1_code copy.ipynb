   "source": [
    "import numpy as np\n",
    "from scipy import stats\n",
    "from tqdm import tqdm\n",
    "\n",
    "perms = True\n",
    "reps = 10\n",
    "\n",
    "permuted_grnd_taskPerf = []\n",
    "\n",
    "if perms:\n",
    "    # 1. PRE-COMPUTATION STEP (Huge Speedup)\n",
    "    # Convert DataFrames to a cache of NumPy arrays and pre-calculate Sums.\n",
    "    # This prevents 'dropna' and 'drop column' from running inside the loop.\n",
    "    video_cache = {}\n",
    "    valid_keys = []\n",
    "    \n",
    "    for v, df in ground_rating_data.items():\n",
    "        if df.empty: continue\n",
    "        \n",
    "        clean_df = df.dropna()\n",
    "        if clean_df.empty: continue\n",
    "\n",
    "        valid_keys.append(v)\n",
    "        video_cache[v] = {\n",
    "            'data': clean_df.values,            # Numpy array of ratings\n",
    "            'cols': clean_df.columns.tolist(),  # List of subjects\n",
    "            'col_map': {s: i for i, s in enumerate(clean_df.columns)}, # Fast lookup\n",
    "            'sum': clean_df.sum(axis=1).values, # Row sums\n",
    "            'n': clean_df.shape[1]              # Number of subjects\n",
    "        }\n",
    "\n",
    "    # 2. PERMUTATION LOOP\n",
    "    for i in tqdm(range(reps)):\n",
    "        \n",
    "        # Sample with replacement (Bootstrapping logic)\n",
    "        # Note: Use replace=False if you want a strict permutation (shuffling) without repeats\n",
    "        p1_keys = np.random.choice(valid_keys, size=len(valid_keys), replace=True)\n",
    "        p2_keys = np.random.choice(valid_keys, size=len(valid_keys), replace=True)\n",
    "\n",
    "        perm_taskPerf = {}\n",
    "\n",
    "        for k1, k2 in zip(p1_keys, p2_keys):\n",
    "            v1 = video_cache[k1]\n",
    "            v2 = video_cache[k2]\n",
    "            \n",
    "            # Pre-calculate truncation length once per video pair\n",
    "            # (Length of video 1 vs Length of video 2)\n",
    "            limit = min(v1['data'].shape[0], v2['data'].shape[0])\n",
    "            if limit < 2: continue # Skip if overlap is too short for correlation\n",
    "\n",
    "            # Iterate through subjects in Video 1\n",
    "            for subj, col_idx in v1['col_map'].items():\n",
    "                if subj not in perm_taskPerf:\n",
    "                    perm_taskPerf[subj] = []\n",
    "\n",
    "                # Get Subject Vector (Video 1)\n",
    "                sr = v1['data'][:limit, col_idx]\n",
    "\n",
    "                # Get Consensus Vector (Video 2)\n",
    "                # OPTIMIZATION: Instead of df.drop(), use (Sum - Self) / (N-1)\n",
    "                if subj in v2['col_map']:\n",
    "                    # Subject exists in V2: Subtract their data from total sum\n",
    "                    s2_idx = v2['col_map'][subj]\n",
    "                    s2_data = v2['data'][:limit, s2_idx]\n",
    "                    v2_sum  = v2['sum'][:limit]\n",
    "                    \n",
    "                    # Consensus = (Total - Subject) / (N - 1)\n",
    "                    cr = (v2_sum - s2_data) / (v2['n'] - 1)\n",
    "                else:\n",
    "                    # Subject not in V2: Just take mean of all\n",
    "                    cr = v2['sum'][:limit] / v2['n']\n",
    "\n",
    "                # Compute Spearman Correlation\n",
    "                # Note: Spearman is slower than Pearson. If speed is critical and \n",
    "                # data is continuous, consider Pearson or pre-ranking.\n",
    "                r, p = stats.spearmanr(sr, cr)\n",
    "                \n",
    "                if not np.isnan(r):\n",
    "                    perm_taskPerf[subj].append(r)\n",
    "\n",
    "        # 3. AGGREGATE RESULTS\n",
    "        # Filter out empty subjects and compute Fisher-Z means\n",
    "        subj_means = [\n",
    "            corrmean(scores) \n",
    "            for scores in perm_taskPerf.values() \n",
    "            if scores\n",
    "        ]\n",
    "        \n",
    "        if subj_means:\n",
    "            permuted_grnd_taskPerf.append(corrmean(subj_means))\n",
    "        else:\n",
    "            permuted_grnd_taskPerf.append(np.nan)"
   ]
  },
