    "def get_next_key(key):\n",
    "    \"\"\"Increments the prefix number while preserving zero-padding.\"\"\"\n",
    "    num, suffix = key.split(\"_\", 1)\n",
    "    return f\"{int(num) + 1:0{len(num)}d}_{suffix}\"\n",
    "\n",
    "# 1. Rename Ground Gaze (Dictionary Comprehension)\n",
    "ground_gaze_data = {get_next_key(k): v for k, v in ground_gaze_data.items()}\n",
    "\n",
    "# 2. Rename & Filter Ground Rating (Done in one pass)\n",
    "ground_rating_data = {\n",
    "    get_next_key(k): v \n",
    "    for k, v in ground_rating_data.items() \n",
    "    if len(v) > 0\n",
    "}\n",
    "\n",
    "# 3. Filter Context Rating\n",
    "context_rating_data = {k: v for k, v in context_rating_data.items() if len(v) > 0}"
   ]
