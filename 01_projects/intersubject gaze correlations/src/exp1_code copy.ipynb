   "source": [
    "\n",
    "## ground condition\n",
    "ground_taskPerf_fi = {}\n",
    "ground_taskPerf_valence_fi = {}\n",
    "ground_taskPerf_arousal_fi = {}\n",
    "\n",
    "# iterate through the videos\n",
    "for video in ground_rating_data:\n",
    "\n",
    "    df = ground_rating_data[video].dropna() # drop na rows\n",
    "\n",
    "    for subj in df.columns:\n",
    "        if subj not in ground_taskPerf_fi: # add subject to our dict\n",
    "            ground_taskPerf_fi[subj] = []\n",
    "            ground_taskPerf_valence_fi[subj] = []\n",
    "            ground_taskPerf_arousal_fi[subj] = []\n",
    "\n",
    "        sr = df[subj]\n",
    "        cr = df.drop(columns = [subj]).mean(axis = 1)\n",
    "        r, p = stats.pearsonr(sr,cr)\n",
    "        ground_taskPerf[subj].append(r)\n",
    "\n",
    "        if 'valence' in video:\n",
    "            ground_taskPerf_valence_fi[subj].append(r)\n",
    "        else:\n",
    "            ground_taskPerf_arousal_fi[subj].append(r)\n",
    "\n",
    "# compute average performance\n",
    "ground_avg_taskPerf_fi = {s:corrmean(ground_taskPerf_fi[s]) for s in ground_taskPerf_fi}\n",
    "ground_avg_taskPerf_valence_fi = {s:corrmean(ground_taskPerf_valence_fi[s]) for s in ground_taskPerf_valence_fi}\n",
    "ground_avg_taskPerf_arousal_fi = {s:corrmean(ground_taskPerf_arousal_fi[s]) for s in ground_taskPerf_arousal_fi}\n",
    "\n",
    "## context condition\n",
    "context_taskPerf_fi = {}\n",
    "context_taskPerf_valence_fi = {}\n",
    "context_taskPerf_arousal_fi = {}\n",
    "\n",
    "# iterate through the videos\n",
    "for video in context_rating_data:\n",
    "    if 'ground' in video:\n",
    "        continue\n",
    "    \n",
    "    df = context_rating_data[video].dropna() # drop na rows\n",
    "    fi_df = ground_rating_data[video].dropna()\n",
    "    for subj in df.columns:\n",
    "        if subj not in context_taskPerf_fi: # add subject to our dict\n",
    "            context_taskPerf_fi[subj] = []\n",
    "            context_taskPerf_valence_fi[subj] = []\n",
    "            context_taskPerf_arousal_fi[subj] = []\n",
    "\n",
    "        sr = df[subj]\n",
    "        cr = fi_df.mean(axis = 1)\n",
    "        co = min(len(sr),len(cr))\n",
    "\n",
    "        r, p = stats.pearsonr(sr[:co],cr[:co])\n",
    "        context_taskPerf_fi[subj].append(r)\n",
    "\n",
    "        if 'valence' in video:\n",
    "            context_taskPerf_valence_fi[subj].append(r)\n",
    "        else:\n",
    "            context_taskPerf_arousal_fi[subj].append(r)\n",
    "\n",
    "# compute average performance\n",
    "context_avg_taskPerf_fi = {s:corrmean(context_taskPerf_fi[s]) for s in context_taskPerf_fi}\n",
    "context_avg_taskPerf_valence_fi = {s:corrmean(context_taskPerf_valence[s]) for s in context_taskPerf_valence}\n",
    "context_avg_taskPerf_arousal_fi = {s:corrmean(context_taskPerf_arousal[s]) for s in context_taskPerf_arousal}\n"
   ]
