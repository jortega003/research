    "import pandas as pd\n",
    "from sklearn.preprocessing import StandardScaler\n",
    "from sklearn.decomposition import PCA\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "\n",
    "df =  filtered_df[['AQ','EQ','Valence','Arousal']].reset_index(drop=True)\n",
    "\n",
    "# standardize values\n",
    "scaler = StandardScaler()\n",
    "scaled_data = scaler.fit_transform(df)\n",
    "\n",
    "# pca\n",
    "pca = PCA()\n",
    "pca_result = pca.fit_transform(scaled_data)\n",
    "\n",
    "# Explained variance\n",
    "explained_var = pca.explained_variance_ratio_\n",
    "cumulative_var = np.cumsum(explained_var)\n",
    "\n",
    "pca_2 = PCA(n_components=2)\n",
    "pca_2_result = pca_2.fit_transform(scaled_data)\n",
    "pca_df = pd.DataFrame(pca_2_result, columns=['PC1', 'PC2'])\n",
    "final_df = pd.concat([df, pca_df], axis=1)\n",
    "\n",
    "# add pid\n",
    "final_df['PID'] = list(filtered_df['PID'])\n",
    "\n",
    "high_group = final_df[final_df['PC1'] <= final_df['PC1'].median()]['PID']\n",
    "low_group = final_df[final_df['PC1'] > final_df['PC1'].median()]['PID']\n"
   ]
