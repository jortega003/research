    "import numpy as np\n",
    "import pandas as pd\n",
    "from collections import defaultdict\n",
    "\n",
    "# Configuration\n",
    "WINDOW_SIZE = 350\n",
    "STEP_SIZE = 10  # How many samples to slide (smaller = smoother but slower)\n",
    "\n",
    "# Storage for rolling results: {subject: [score_t1, score_t2, ...]}\n",
    "rolling_context_isc = defaultdict(list)\n",
    "\n",
    "for video in context_gaze_data:\n",
    "    if 'pupil' in video: \n",
    "        continue\n",
    "\n",
    "    # 1. Clean Data\n",
    "    # Drop columns that are all NaN, then drop rows with any NaNs (blinks)\n",
    "    df = context_gaze_data[video].dropna(axis=1, how='all').dropna()\n",
    "    \n",
    "    # 2. Iterate with Sliding Window\n",
    "    num_samples = len(df)\n",
    "    \n",
    "    # If video is shorter than window, skip or take the whole thing\n",
    "    if num_samples < WINDOW_SIZE:\n",
    "        continue\n",
    "        \n",
    "    for start_idx in range(0, num_samples - WINDOW_SIZE + 1, STEP_SIZE):\n",
    "        end_idx = start_idx + WINDOW_SIZE\n",
    "        \n",
    "        # Get the window slice\n",
    "        window_df = df.iloc[start_idx:end_idx]\n",
    "        \n",
    "        # 3. Calculate CCC for this window\n",
    "        # (Using your ccc_matrix function from previous steps)\n",
    "        # We replace diagonal (1.0) with NaN to ignore self-correlation\n",
    "        ccc_mat = ccc_matrix(window_df).replace(1.0, np.nan)\n",
    "        \n",
    "        # 4. Compute Mean ISC for each subject in this window\n",
    "        # Axis 0 or 1 doesn't matter for symmetric matrix, but 1 is \"columns\"\n",
    "        window_means = ccc_mat.mean(axis=1)\n",
    "        \n",
    "        # 5. Store the result\n",
    "        for subj, score in window_means.items():\n",
    "            rolling_context_isc[subj].append(score)\n",
    "\n",
    "# Optional: Aggregate strictly by time if you want a single time-course\n",
    "# (This part depends on if you want to keep video structure or just concatenate everything)"
