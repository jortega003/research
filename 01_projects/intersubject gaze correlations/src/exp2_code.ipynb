    "def ccc_matrix(df, alpha=1.0):\n",
    "    cols = df.columns\n",
    "    n = len(cols)\n",
    "    # Initialize an empty matrix\n",
    "    matrix = pd.DataFrame(np.eye(n), index=cols, columns=cols)\n",
    "\n",
    "    for i in range(n):\n",
    "        for j in range(i + 1, n):\n",
    "            x, y = df.iloc[:, i], df.iloc[:, j]\n",
    "            \n",
    "            # Components\n",
    "            sxy = np.cov(x, y)[0, 1]\n",
    "            vx, vy = np.var(x), np.var(y)\n",
    "            rho = sxy / (np.sqrt(vx) * np.sqrt(vy))\n",
    "            cb = 2 * sxy / (vx + vy + (np.mean(x) - np.mean(y))**2) / rho\n",
    "            \n",
    "            # Fill symmetric values\n",
    "            val = (rho ** alpha) * cb\n",
    "            matrix.iloc[i, j] = matrix.iloc[j, i] = val\n",
    "            \n",
    "    return matrix"
   ]
