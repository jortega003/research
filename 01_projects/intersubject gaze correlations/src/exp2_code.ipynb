    "import numpy as np\n",
    "from scipy import stats\n",
    "from tqdm import tqdm\n",
    "\n",
    "def fisher_mean(correlations):\n",
    "    \"\"\"Computes the mean of correlations using Fisher Z-transformation.\"\"\"\n",
    "    # Clip to avoid infinity at r=1.0 or r=-1.0\n",
    "    correlations = np.clip(correlations, -0.99999, 0.99999)\n",
    "    z_vals = np.arctanh(correlations)\n",
    "    mean_z = np.nanmean(z_vals)\n",
    "    return np.tanh(mean_z)\n",
    "\n",
    "def fast_spearman_col_wise(X, Y):\n",
    "    \"\"\"\n",
    "    Computes Spearman correlation column-wise between Matrix X and Matrix Y.\n",
    "    X and Y must have shape (Time, Subjects).\n",
    "    Returns a vector of correlations of shape (Subjects,).\n",
    "    \"\"\"\n",
    "    # 1. Rank data along the time axis (axis 0)\n",
    "    X_ranked = stats.rankdata(X, axis=0)\n",
    "    Y_ranked = stats.rankdata(Y, axis=0)\n",
    "    \n",
    "    # 2. Center the ranks (subtract mean)\n",
    "    X_centered = X_ranked - X_ranked.mean(axis=0)\n",
    "    Y_centered = Y_ranked - Y_ranked.mean(axis=0)\n",
    "    \n",
    "    # 3. Compute cosine similarity (Pearson on ranks)\n",
    "    # sum(x*y) / (sqrt(sum(x^2)) * sqrt(sum(y^2)))\n",
    "    numer = np.sum(X_centered * Y_centered, axis=0)\n",
    "    denom = np.sqrt(np.sum(X_centered**2, axis=0)) * np.sqrt(np.sum(Y_centered**2, axis=0))\n",
    "    \n",
    "    # Handle division by zero if variance is 0\n",
    "    return np.divide(numer, denom, out=np.zeros_like(numer), where=denom!=0)\n",
    "\n",
    "# --- 1. Pre-computation Phase ---\n",
    "# Convert Dict of DFs to Dict of Numpy Arrays to remove Pandas overhead from loop\n",
    "# Structure: video_data[video_key] = { 'data': np_array, 'columns': list_of_subjects }\n",
    "video_data = {}\n",
    "video_keys = list(context_rating_data.keys())\n",
    "\n",
    "for v in video_keys:\n",
    "    # Drop NA once per video beforehand\n",
    "    clean_df = context_rating_data[v].dropna()\n",
    "    video_data[v] = {\n",
    "        'data': clean_df.to_numpy(),\n",
    "        'subjects': clean_df.columns.tolist(),\n",
    "        'is_valence': 'valence' in v # Pre-check condition\n",
    "    }\n",
    "\n",
    "a_perm = []\n",
    "v_perm = []\n",
    "\n",
    "# --- 2. Permutation Loop ---\n",
    "n_perms = 10\n",
    "for _ in tqdm(range(n_perms)):\n",
    "    \n",
    "    perm_valence_corrs = []\n",
    "    perm_arousal_corrs = []\n",
    "    \n",
    "    # Create shuffled keys\n",
    "    shuffled_keys = np.random.choice(video_keys, len(video_keys), replace=False)\n",
    "\n",
    "    for v1_key, v2_key in zip(video_keys, shuffled_keys):\n",
    "        \n",
    "        # Get pre-processed data\n",
    "        v1_struct = video_data[v1_key]\n",
    "        v2_struct = video_data[v2_key]\n",
    "        \n",
    "        # Ensure dimensionality matches for correlation (Time dimension)\n",
    "        # Note: If v1 and v2 have different frame counts (rows), Spearman will fail.\n",
    "        # We assume here min_length truncation to keep it running, or strict equality.\n",
    "        min_len = min(v1_struct['data'].shape[0], v2_struct['data'].shape[0])\n",
    "        \n",
    "        # Extract matrices (Time x Subjects)\n",
    "        mat_v1 = v1_struct['data'][:min_len, :] \n",
    "        mat_v2 = v2_struct['data'][:min_len, :]\n",
    "        \n",
    "        # --- Vectorized LOO Consensus ---\n",
    "        # Calculate consensus for v2 (the shuffled video)\n",
    "        # Math: Mean_Others_i = (Sum_All_Rows - Value_i) / (N_Cols - 1)\n",
    "        sum_rows = np.sum(mat_v2, axis=1, keepdims=True)\n",
    "        n_subjs = mat_v2.shape[1]\n",
    "        \n",
    "        if n_subjs > 1:\n",
    "            # This creates a matrix where col [i] is the mean of all cols except [i]\n",
    "            consensus_mat_v2 = (sum_rows - mat_v2) / (n_subjs - 1)\n",
    "        else:\n",
    "            # If only 1 subject, no consensus possible\n",
    "            continue\n",
    "\n",
    "        # --- Vectorized Spearman ---\n",
    "        # Correlate every subject in V1 with their specific LOO consensus in V2\n",
    "        # Result is a vector of r-values (one per subject)\n",
    "        r_values = fast_spearman_col_wise(mat_v1, consensus_mat_v2)\n",
    "        \n",
    "        # Store results\n",
    "        if v1_struct['is_valence']:\n",
    "            perm_valence_corrs.extend(r_values)\n",
    "        else:\n",
    "            perm_arousal_corrs.extend(r_values)\n",
    "\n",
    "    # Compute average performance for this permutation\n",
    "    # Using Fisher Mean (Standard for aggregating correlations)\n",
    "    if perm_valence_corrs:\n",
    "        v_perm.append(fisher_mean(perm_valence_corrs))\n",
    "    else:\n",
    "        v_perm.append(np.nan)\n",
    "        \n",
    "    if perm_arousal_corrs:\n",
    "        a_perm.append(fisher_mean(perm_arousal_corrs))\n",
    "    else:\n",
    "        a_perm.append(np.nan)"
   ]
