    "import numpy as np\n",
    "from tqdm import tqdm\n",
    "\n",
    "# Helper: Fisher Z-Transformation Mean\n",
    "def fisher_mean(correlations):\n",
    "    # Clip to ensure we don't hit infinity\n",
    "    correlations = np.clip(correlations, -0.999999, 0.999999)\n",
    "    z_vals = np.arctanh(correlations)\n",
    "    return np.tanh(np.nanmean(z_vals))\n",
    "\n",
    "# Helper: Fast Column-wise Pearson Correlation\n",
    "def fast_col_corr(A, B):\n",
    "    # A and B must be (Time, Subjects)\n",
    "    # 1. Center the data\n",
    "    A_c = A - np.mean(A, axis=0)\n",
    "    B_c = B - np.mean(B, axis=0)\n",
    "    \n",
    "    # 2. Compute covariance (numerator)\n",
    "    numer = np.sum(A_c * B_c, axis=0)\n",
    "    \n",
    "    # 3. Compute variances (denominator)\n",
    "    denom = np.sqrt(np.sum(A_c**2, axis=0)) * np.sqrt(np.sum(B_c**2, axis=0))\n",
    "    \n",
    "    # 4. Divide (handle divide by zero)\n",
    "    return np.divide(numer, denom, out=np.zeros_like(numer), where=denom!=0)\n",
    "\n",
    "# --- 1. Pre-computation Phase ---\n",
    "clean_gaze_data = {}\n",
    "valid_video_keys = []\n",
    "\n",
    "print(\"Pre-processing video data...\")\n",
    "for v_key in context_gaze_data:\n",
    "    # Filter 'pupil' videos here once\n",
    "    if 'pupil' in v_key:\n",
    "        continue\n",
    "        \n",
    "    # Run expensive cleaning ONCE\n",
    "    # Assuming outlier_remover returns a DataFrame\n",
    "    clean_df = context_gaze_data[v_key]\n",
    "    \n",
    "    # Store as NumPy array for speed\n",
    "    clean_gaze_data[v_key] = clean_df.to_numpy()\n",
    "    valid_video_keys.append(v_key)\n",
    "\n",
    "# --- 2. Permutation Loop ---\n",
    "isc_perm = []\n",
    "n_perms = 10\n",
    "\n",
    "print(\"Running permutations...\")\n",
    "for _ in tqdm(range(n_perms)):\n",
    "    \n",
    "    perm_correlations = []\n",
    "    \n",
    "    # Create shuffled keys\n",
    "    shuffled_keys = np.random.choice(valid_video_keys, len(valid_video_keys), replace=False)\n",
    "    \n",
    "    for v_orig, v_shuff in zip(valid_video_keys, shuffled_keys):\n",
    "        \n",
    "        data_orig = clean_gaze_data[v_orig]\n",
    "        data_shuff = clean_gaze_data[v_shuff]\n",
    "        \n",
    "        # Truncate to minimum length to ensure matrix alignment\n",
    "        min_len = min(data_orig.shape[0], data_shuff.shape[0])\n",
    "        if min_len < 2: continue # Skip if data is too short\n",
    "            \n",
    "        mat_A = data_orig[:min_len]\n",
    "        mat_B = data_shuff[:min_len]\n",
    "        \n",
    "        # Compute correlation for all subjects at once\n",
    "        # Result is an array of shape (n_subjects,)\n",
    "        r_vals = fast_col_corr(mat_A, mat_B)\n",
    "        \n",
    "        # Store valid correlations\n",
    "        perm_correlations.extend(r_vals[~np.isnan(r_vals)])\n",
    "\n",
    "    # Compute final average for this permutation\n",
    "    if perm_correlations:\n",
    "        isc_perm.append(fisher_mean(np.array(perm_correlations)))\n",
    "    else:\n",
    "        isc_perm.append(np.nan)"
   ]
